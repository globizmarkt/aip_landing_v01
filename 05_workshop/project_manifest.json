{
  "project_id": "aip-v1",
  "schema_version": "1.0.0",
  "created_at": "2026-03-17",
  "source": "AIP Core Refactoring",

  "metadata": {
    "tier": "startup",
    "vertical": "AIP",
    "brand_name": "Atlantis International Projects",
    "brand_short": "AIP",
    "tagline": "UK-based, globally connected",
    "jurisdiction": "UK",
    "subdomains": ["mesa.aip.digital", "agentes.aip.digital"]
  },

  "brand": {
    "theme": "deep-ocean-uk-gold",
    "colors": {
      "bg_primary": "#0a1628",
      "bg_elevated": "#112240",
      "bg_card": "#1a3356",
      "accent": "#c9a84c",
      "accent_light": "#e8c96d",
      "text_primary": "#f0f4f8",
      "text_muted": "#8ba3c7",
      "border": "#1e3a5f",
      "success": "#10b981",
      "warning": "#f59e0b",
      "danger": "#ef4444"
    },
    "typography": {
      "font_primary": "Inter",
      "font_serif": "Playfair Display",
      "use_serif_for": ["headings", "deal_titles", "institutional_labels"]
    }
  },

  "offering_config": {
    "item_type_families": [

      {
        "family": "INSTRUMENTS",
        "label": "Instrumentos Bancarios",
        "item_type": "Banking_Instrument",
        "desk": "Banking Instruments Desk",
        "role_access": ["SuperAdmin", "Partner", "DeskManager:Instruments"],
        "kyc_required": true,
        "fields": [
          { "key": "instrument_type", "type": "select", "options": ["SBLC", "BG", "LC", "MTN", "Bond"], "required": true },
          { "key": "issuing_bank", "type": "string", "required": true },
          { "key": "instrument_amount", "type": "number", "currency": "USD", "required": true },
          { "key": "verbiage_type", "type": "select", "options": ["URDG 758", "UCP 600", "ISP98"], "required": true },
          { "key": "monetization_ready", "type": "boolean", "default": false },
          { "key": "operation_type", "type": "select", "options": ["Emision", "Monetizacion", "PPP"], "required": true },
          { "key": "counterparty_risk", "type": "select", "options": ["Low", "Medium", "High"] },
          { "key": "contract_file_cid", "type": "file_ref", "storage": "cloud_storage" },
          { "key": "compliance_check", "type": "boolean", "default": false },
          { "key": "status", "type": "select", "options": ["LOI", "Draft", "Signed", "Active", "Expired", "Closed"] }
        ]
      },

      {
        "family": "ADVISORY",
        "label": "Corporate Finance & Advisory",
        "item_type": "Advisory_Deal",
        "desk": "Corporate & Project Finance",
        "role_access": ["SuperAdmin", "Partner", "DeskManager:Advisory"],
        "kyc_required": true,
        "fields": [
          { "key": "deal_type", "type": "select", "options": ["M&A", "Project Finance", "Restructuring", "Valuation", "PPP"], "required": true },
          { "key": "sector", "type": "select", "options": ["Infrastructure", "Energy", "Real Estate", "Technology", "Healthcare", "Other"] },
          { "key": "deal_value", "type": "number", "currency": "USD", "required": true },
          { "key": "funding_gap", "type": "number", "currency": "USD" },
          { "key": "collateral_type", "type": "select", "options": ["SBLC", "Real Estate", "Cash", "Gold", "Other"] },
          { "key": "valuation_method", "type": "select", "options": ["DCF", "Comparables", "NAV", "Custom"] },
          { "key": "due_diligence_stage", "type": "select", "options": ["Pre-NDA", "NDA Signed", "DD In Progress", "DD Complete", "Term Sheet", "Closing"], "required": true },
          { "key": "target_value", "type": "number", "currency": "USD" },
          { "key": "closing_date_est", "type": "date" },
          { "key": "dataroom_link", "type": "url" }
        ]
      },

      {
        "family": "COMMODITIES",
        "label": "Commodities & Assets",
        "item_type": "Trade_Asset",
        "desk": "Commodities & Assets Desk",
        "role_access": ["SuperAdmin", "Partner", "DeskManager:Commodities", "CountryHead", "Agent"],
        "kyc_required": true,
        "fields": [
          { "key": "commodity_type", "type": "select", "options": ["Sugar ICUMSA 45", "Crude Oil", "Gold", "Fertilizers", "Flour", "Other"], "required": true },
          { "key": "asset_class", "type": "select", "options": ["Commodity", "Real Estate Singular", "Mine", "Historical Bond", "Precious Stone"] },
          { "key": "quantity_mt", "type": "number", "unit": "Metric Tons" },
          { "key": "moq", "type": "number", "unit": "Metric Tons", "label": "Minimum Order Quantity" },
          { "key": "origin_country", "type": "string", "required": true },
          { "key": "incoterms", "type": "select", "options": ["CIF", "FOB", "EXW", "DDP", "CFR"], "required": true },
          { "key": "grade", "type": "string", "label": "Calidad / Pureza" },
          { "key": "loading_port", "type": "string" },
          { "key": "procedure_protocol", "type": "select", "options": ["LOI → SCO → SPA", "ICPO → FCO → Contract", "Custom"] },
          { "key": "price_usd_per_mt", "type": "number", "currency": "USD" },
          { "key": "risk_score", "type": "select", "options": ["Low", "Medium", "High"] },
          { "key": "status", "type": "select", "options": ["LOI Sent", "SCO Received", "SPA Negotiation", "Signed", "Shipped", "Closed"] }
        ]
      },

      {
        "family": "COMPLIANCE",
        "label": "Compliance & Paymaster",
        "item_type": "Compliance_Record",
        "desk": "AML & Process Consulting",
        "role_access": ["SuperAdmin", "Partner", "DeskManager:Compliance"],
        "kyc_required": true,
        "fields": [
          { "key": "client_type", "type": "select", "options": ["Individual HNWI", "Family Office", "Corporate", "Fund", "Institution"] },
          { "key": "kyc_status", "type": "select", "options": ["Not Started", "Pending", "In Review", "Verified", "Rejected"], "required": true },
          { "key": "kyb_status", "type": "select", "options": ["Not Required", "Pending", "Verified"], "required": false },
          { "key": "source_of_funds_provenance", "type": "string", "required": true },
          { "key": "aml_risk_level", "type": "select", "options": ["Low", "Medium", "High", "PEP"] },
          { "key": "jurisdiction", "type": "string" },
          { "key": "paymaster_agreement_signed", "type": "boolean", "default": false },
          { "key": "pbc_check_date", "type": "date" },
          { "key": "passport_file_cid", "type": "file_ref", "storage": "firestore_secure" },
          { "key": "bank_statement_file_cid", "type": "file_ref", "storage": "firestore_secure" },
          { "key": "compliance_notes", "type": "text" }
        ]
      }

    ]
  },

  "gatekeeper": {
    "active_limits": {
      "seed": { "max_items": 5, "max_users": 1, "kyc_access": false, "desk_access": ["ADVISORY"] },
      "startup": { "max_items": -1, "max_users": 50, "kyc_access": true, "desk_access": ["INSTRUMENTS", "ADVISORY", "COMMODITIES", "COMPLIANCE"] },
      "enterprise": { "max_items": -1, "max_users": -1, "kyc_access": true, "desk_access": "all" }
    },
    "compliance_gates": {
      "instruments_desk_requires_kyc": true,
      "commodities_desk_requires_kyc": true,
      "ppp_requires_kyc_and_kyb": true,
      "pre_qualification_allowed_in_seed": true
    },
    "jurisdiction_rules": {
      "base_legal": "UK",
      "disclaimer_language": "auto_detect_by_agent_region",
      "gdpr_apply_to": ["EU", "UK"]
    }
  },

  "dashboard": {
    "layout": "trinity",
    "left_nav": {
      "width": "250px",
      "collapsible": true,
      "items": ["instruments", "trade_finance", "advisory", "compliance", "agents_map"]
    },
    "canvas": {
      "default_widgets": [
        { "widget_id": "wd-trade-desk", "cols": 12, "rows": 4, "desk": "INSTRUMENTS" },
        { "widget_id": "wd-offering-card", "cols": 6, "rows": 2, "desk": "COMMODITIES" },
        { "widget_id": "wd-project-finance", "cols": 6, "rows": 2, "desk": "ADVISORY" },
        { "widget_id": "wd-compliance-check", "cols": 12, "rows": 3, "desk": "COMPLIANCE" },
        { "widget_id": "wd-agent-tracker", "cols": 12, "rows": 4, "desk": "AGENTS", "role": "SuperAdmin" }
      ]
    },
    "right_inspector": {
      "width": "320px",
      "always_visible": true,
      "panels": ["aimon", "gatekeeper_status", "metadata_inspector"]
    }
  }
}
